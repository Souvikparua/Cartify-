{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth":       { "ClusterId": "auth",       "Match": { "Path": "/api/auth/{**catch-all}" } },
      "users":      { "ClusterId": "users",       "Match": { "Path": "/api/users/{**catch-all}" } },
      "products":   { "ClusterId": "products",    "Match": { "Path": "/api/products/{**catch-all}" } },
      "orders":     { "ClusterId": "orders",      "Match": { "Path": "/api/orders/{**catch-all}" } },
      "cart":       { "ClusterId": "cart",        "Match": { "Path": "/api/cart/{**catch-all}" } },
      "promotions": { "ClusterId": "promotions",  "Match": { "Path": "/api/promotions/{**catch-all}" } },
      "dealers":    { "ClusterId": "dealers",     "Match": { "Path": "/api/dealers/{**catch-all}" } },
      "delivery":   { "ClusterId": "delivery",    "Match": { "Path": "/api/delivery/{**catch-all}" } }
    },
    "Clusters": {
      "auth":       { "Destinations": { "d1": { "Address": "http://localhost:5163" } } },
      "users":      { "Destinations": { "d1": { "Address": "http://localhost:5230" } } },
      "products":   { "Destinations": { "d1": { "Address": "http://localhost:5202" } } },
      "orders":     { "Destinations": { "d1": { "Address": "http://localhost:5090" } } },
      "cart":       { "Destinations": { "d1": { "Address": "http://localhost:5219" } } },
      "promotions": { "Destinations": { "d1": { "Address": "http://localhost:5240" } } },
      "dealers":    { "Destinations": { "d1": { "Address": "http://localhost:5250" } } },
      "delivery":   { "Destinations": { "d1": { "Address": "http://localhost:5260" } } }
    }
  }
}
